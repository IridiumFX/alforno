{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 20, "patch": 0 },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (Ninja)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release (Ninja)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "macos-arm64",
      "displayName": "macOS arm64 (cross)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "ALF_BUILD_TESTS": "OFF"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "ios-arm64",
      "displayName": "iOS arm64 (static)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_SYSTEM_NAME": "iOS",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "13.0",
        "BUILD_SHARED_LIBS": "OFF",
        "ALF_BUILD_TESTS": "OFF"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "ios-simulator",
      "displayName": "iOS Simulator arm64 (static)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_SYSTEM_NAME": "iOS",
        "CMAKE_OSX_ARCHITECTURES": "arm64",
        "CMAKE_OSX_DEPLOYMENT_TARGET": "13.0",
        "CMAKE_OSX_SYSROOT": "iphonesimulator",
        "BUILD_SHARED_LIBS": "OFF",
        "ALF_BUILD_TESTS": "OFF"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "android-arm64",
      "displayName": "Android arm64-v8a (static)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_SYSTEM_NAME": "Android",
        "CMAKE_ANDROID_ARCH_ABI": "arm64-v8a",
        "CMAKE_ANDROID_API": "21",
        "CMAKE_ANDROID_NDK": "$env{ANDROID_NDK_HOME}",
        "BUILD_SHARED_LIBS": "OFF",
        "ALF_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "android-arm32",
      "displayName": "Android armeabi-v7a (static)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_SYSTEM_NAME": "Android",
        "CMAKE_ANDROID_ARCH_ABI": "armeabi-v7a",
        "CMAKE_ANDROID_API": "21",
        "CMAKE_ANDROID_NDK": "$env{ANDROID_NDK_HOME}",
        "BUILD_SHARED_LIBS": "OFF",
        "ALF_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "bsd-amd64",
      "displayName": "BSD amd64 (shared)",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      },
      "condition": {
        "type": "anyOf",
        "conditions": [
          { "type": "equals", "lhs": "${hostSystemName}", "rhs": "FreeBSD" },
          { "type": "equals", "lhs": "${hostSystemName}", "rhs": "NetBSD" },
          { "type": "equals", "lhs": "${hostSystemName}", "rhs": "OpenBSD" },
          { "type": "equals", "lhs": "${hostSystemName}", "rhs": "DragonFly" }
        ]
      }
    },
    {
      "name": "bsd-amd64-static",
      "displayName": "BSD amd64 (static)",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_SHARED_LIBS": "OFF"
      },
      "condition": {
        "type": "anyOf",
        "conditions": [
          { "type": "equals", "lhs": "${hostSystemName}", "rhs": "FreeBSD" },
          { "type": "equals", "lhs": "${hostSystemName}", "rhs": "NetBSD" },
          { "type": "equals", "lhs": "${hostSystemName}", "rhs": "OpenBSD" },
          { "type": "equals", "lhs": "${hostSystemName}", "rhs": "DragonFly" }
        ]
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "configurePreset": "default"
    },
    {
      "name": "release",
      "configurePreset": "release"
    }
  ]
}
