; Platform assembly — links tls and observability into app descriptor

@app {
    name: "{service}-service",
    port: 9090,
    workers: 8,
    log_level: "warn",
    debug: false,
    timeout: 45,
    max_connections: 1000,
    tls: tls,
    telemetry: observability
}

@db {
    engine: "postgres",
    host: "db-primary.{region}.internal",
    name: "{service}_prod",
    port: 5432,
    pool_min: 5,
    pool_max: 150,
    ssl: true,
    timeout: 10
}

@tls {
    enabled: true,
    cert: "/etc/ssl/certs/{region}/{env}.pem",
    key: "/etc/ssl/private/{region}/{env}.key",
    protocols: ["TLSv1.2", "TLSv1.3"],
    verify: true
}

@observability {
    metrics_enabled: true,
    tracing_enabled: true,
    log_format: "json",
    sample_rate: 0.01,
    metrics_endpoint: "https://metrics.{region}.internal/ingest",
    tracing_endpoint: "https://tracing.{region}.internal/ingest"
}
